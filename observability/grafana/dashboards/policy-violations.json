{
  "annotations": { "list": [] },
  "description": "Kyverno policy violation trends — blocked requests, audit findings, policy stats",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "Violations by Policy (24h)",
      "type": "piechart",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "sum(increase(kyverno_policy_results_total{rule_result=\"fail\"}[24h])) by (policy_name)",
          "legendFormat": "{{ policy_name }}"
        }
      ]
    },
    {
      "title": "Violations by Team (24h)",
      "type": "barchart",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "sum(increase(kyverno_policy_results_total{rule_result=\"fail\"}[24h])) by (resource_namespace)",
          "legendFormat": "{{ resource_namespace }}"
        }
      ]
    },
    {
      "title": "Violation Rate Over Time",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "sum(rate(kyverno_policy_results_total{rule_result=\"fail\"}[1h])) by (policy_name)",
          "legendFormat": "{{ policy_name }}"
        }
      ]
    },
    {
      "title": "Admission Review Latency (p99)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 16 },
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum(rate(kyverno_admission_review_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p99 latency"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s" }
      }
    }
  ],
  "schemaVersion": 39,
  "tags": ["platform", "kyverno", "policy"],
  "templating": { "list": [] },
  "time": { "from": "now-7d", "to": "now" },
  "title": "Policy Violations",
  "uid": "policy-violations"
}
